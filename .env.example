# Server
PORT=3000

# Environment (production/development)
NODE_ENV=production

# Admin Panel Password (change this!)
ADMIN_PASSWORD=admin123

# API Keys (comma-separated, clients use these to authenticate)
API_KEYS=sk-proxy-key-1,sk-proxy-key-2

# Admin IP Whitelist (optional, comma-separated IPs, leave empty to allow all)
ADMIN_IP_WHITELIST=

# CORS Origin (for production, set to your domain)
CORS_ORIGIN=*

# Upstream Providers
# Format: NAME|BASE_URL|API_KEY|WEIGHT|ENABLED
# Higher weight = more traffic routed to this provider

# OpenRouter (有免费模型，但仍需注册获取 API Key)
# 注册获取 API Key: https://openrouter.ai/keys
# 免费模型列表: https://openrouter.ai/models?max_price=0
PROVIDERS=openrouter-free|https://openrouter.ai/api/v1|your-openrouter-key|5|true

# Groq - 超快推理，14400请求/天
# 注册: https://console.groq.com
PROVIDERS_2=groq|https://api.groq.com/openai/v1|your-groq-key|8|true

# Cerebras - 超快推理，14400请求/天
# 注册: https://cloud.cerebras.ai
PROVIDERS_3=cerebras|https://api.cerebras.ai/v1|your-cerebras-key|7|true

# SambaNova - $5免费额度，含DeepSeek
# 注册: https://cloud.sambanova.ai
PROVIDERS_4=sambanova|https://api.sambanova.ai/v1|your-sambanova-key|6|true

# Google AI Studio (Gemini) - 免费Gemini模型
# 注册: https://aistudio.google.com
PROVIDERS_5=google-ai|https://generativelanguage.googleapis.com/v1beta/openai|your-google-key|5|true

# Mistral - 10亿token/月免费
# 注册: https://console.mistral.ai
PROVIDERS_6=mistral|https://api.mistral.ai/v1|your-mistral-key|5|true

# GitHub Models - GPT-4o等免费
# 注册: https://github.com/marketplace/models
PROVIDERS_7=github-models|https://models.inference.ai.azure.com|your-github-token|4|true

# NVIDIA NIM - 40请求/分钟
# 注册: https://build.nvidia.com
PROVIDERS_8=nvidia-nim|https://integrate.api.nvidia.com/v1|your-nvidia-key|4|true

# Cohere - 免费Command模型
# 注册: https://cohere.com
PROVIDERS_9=cohere|https://api.cohere.com/compatibility/v1|your-cohere-key|3|true

# HYC 好用Ai
# 获取 API Key: https://www.haoyongai.xyz/dashboard
PROVIDERS_10=haoyongai|https://www.haoyongai.xyz/v1|your-haoyongai-key|3|true

# 4sapi 企业级大模型API中转站
# 获取 API Key: https://4sapi.com/pricing
PROVIDERS_11=4sapi|https://new-api.4sapi.com/v1|your-4sapi-key|2|true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Retry
MAX_RETRIES=2
REQUEST_TIMEOUT_MS=60000

# Health Check (v2)
HEALTH_CHECK_INTERVAL_MS=60000

# Logging (v2)
MAX_LOG_ENTRIES=1000

# ========== 安全（必填）==========

# JWT Secret - 用户登录 token 签名密钥（不设置则使用硬编码默认值，极不安全）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Market Encrypt Key - 市场 API Key 加密存储密钥（32 字节，不设置则使用硬编码默认值）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MARKET_ENCRYPT_KEY=

# ========== 邮箱服务（推荐配置）==========

# Resend API（推荐，全球可达，无需 SMTP）
# 注册: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=

# 发件人地址（使用 Resend 时生效，不设则默认 onboarding@resend.dev）
# 自定义域名需在 Resend 后台验证: https://resend.com/domains
EMAIL_FROM=

# SMTP 备用方案（本地开发或 Resend 不可用时使用）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ========== USDT-TRC20（可选，加密货币充值）==========

# 热钱包地址和私钥（用于接收充值和发起提现）
USDT_WALLET_ADDRESS=
USDT_WALLET_PRIVATE_KEY=

# 冷钱包地址（大额资金归集）
USDT_COLD_WALLET=

# 兑换比例：1 USDT = N 金币
USDT_COINS_PER_USDT=10

# 充提限额
USDT_MIN_DEPOSIT=1
USDT_MAX_WITHDRAW=50

# ========== 站点信息（可选）==========

# 站点名称（显示在邮件和页面标题中）
SITE_NAME=LLM API 中转站

# 站点 URL（用于邮件中的链接，不设则默认 Render 地址）
SITE_URL=
